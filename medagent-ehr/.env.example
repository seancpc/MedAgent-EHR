# ─────────────────────────────────────────────────────────────
# medagent-ehr environment configuration
#
# Copy to .env and fill in values ON THE TARGET MACHINE only.
# On the development laptop these sensitive fields stay EMPTY by design.
# ─────────────────────────────────────────────────────────────

# LLM endpoint — llama-server OpenAI-compatible /v1 base.
# Example: http://localhost:11434/v1   (trailing /v1 optional, client normalizes)
OLLAMA_BASE_URL=
# Agent model name. For llama-server this is mostly cosmetic (it serves whatever
# GGUF was loaded with -m); if llama-server is started with --alias, set this
# to match that alias. Example: gemma4-26b-a4b
OLLAMA_MODEL=

# Address of the running fhir-mcp-server, e.g. http://127.0.0.1:9765/mcp
FHIR_MCP_URL=

# Langfuse observability. Leave all three empty to disable tracing.
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- non-sensitive defaults (safe to keep) ---
WEB_HOST=127.0.0.1
WEB_PORT=9443
MAX_STEPS=25
MAX_REPLANS=3
MAX_RETRIES=3
