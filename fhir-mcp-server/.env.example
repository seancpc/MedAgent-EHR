# ─────────────────────────────────────────────────────────────
# fhir-mcp-server environment configuration
#
# Copy to .env and fill in values ON THE TARGET MACHINE only.
# On the development laptop these sensitive fields stay EMPTY by design.
# ─────────────────────────────────────────────────────────────

# Base URL of the HAPI FHIR server, e.g. http://localhost:8080/fhir
FHIR_BASE_URL=

# Bearer token, only if the FHIR server requires auth.
# The HAPI test server needs none — leave empty.
FHIR_AUTH_TOKEN=

# --- non-sensitive defaults (safe to keep) ---
MCP_HOST=127.0.0.1
MCP_PORT=9765
FHIR_TIMEOUT_SECONDS=30
